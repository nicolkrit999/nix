{ delib, pkgs, lib, ... }:
delib.module {
  name = "programs.hyprland";

  nixos.ifEnabled =
    { cfg, myconfig, ... }:
    let
      caelestiaActiveOnHyprland =
        (myconfig.programs.caelestia.enable or false)
        && (myconfig.programs.caelestia.enableOnHyprland or false);
      noctaliaActiveOnHyprland =
        (myconfig.programs.noctalia.enable or false)
        && (myconfig.programs.noctalia.enableOnHyprland or false);

      hyprlandFallback =
        !caelestiaActiveOnHyprland
        && !noctaliaActiveOnHyprland;

      wallpaperCmds = map
        (w:
          let
            imgPath = pkgs.fetchurl { url = w.wallpaperURL; sha256 = w.wallpaperSHA256; };
            target = if w.targetMonitor == "*" then "" else "-o ${w.targetMonitor} ";
          in
          "sh -c 'sleep 1 && awww img ${target}${imgPath}'")
        myconfig.constants.wallpapers;
    in
    lib.mkIf hyprlandFallback {
      myconfig.programs.hyprland.execOnce = [ "awww-daemon" ] ++ wallpaperCmds;
    };
}
